# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit real values.

# --- Shopify (client-credentials grant) ---
# Your store's myshopify domain, e.g. jellycrystal.myshopify.com  (NOT the vanity domain)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
# From Dev Dashboard → your app → Settings → Credentials.
SHOPIFY_CLIENT_ID=
# The client secret is SENSITIVE. It goes ONLY here. If it ever leaks, rotate it in the Dev Dashboard.
SHOPIFY_CLIENT_SECRET=
# Admin API version (Shopify ships quarterly: 2026-01, 2026-04, 2026-07, ...). Bump when ready.
SHOPIFY_API_VERSION=2026-01

# --- Anthropic (used from Phase 2 onward, not needed for the Phase 1 health check) ---
ANTHROPIC_API_KEY=
